# ─────────────────────────────────────────────────────────────
# A.K. Auto Care — environment variables
# Copy to .env.local for local dev, and set the same in Vercel for production.
# NEXT_PUBLIC_* values are exposed to the browser (safe by design).
# ─────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — NEVER expose

# ── Admin panel (REQUIRED) ───────────────────────────────────
# Strong random string. This is the admin login password + session secret.
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.akautocare.pk

# ── Transactional email — Resend (REQUIRED for order emails) ─
RESEND_API_KEY=re_xxxxxxxx
CONTACT_EMAIL_FROM=orders@akautocare.pk
CONTACT_EMAIL_TO=hello@akautocare.pk

# ── Business / contact details (shown across the site) ───────
NEXT_PUBLIC_WHATSAPP_NUMBER=923000000000        # full intl format, no +
NEXT_PUBLIC_CONTACT_EMAIL=hello@akautocare.pk
NEXT_PUBLIC_BUSINESS_ADDRESS=Block 7, PECHS, Karachi — 75400
NEXT_PUBLIC_BUSINESS_HOURS=Mon–Sat · 10 AM – 8 PM
NEXT_PUBLIC_BUSINESS_MAP_QUERY=Block 7 PECHS Karachi Pakistan 75400

# ── Manual payment details (shown at checkout) ───────────────
NEXT_PUBLIC_JAZZCASH_NUMBER=0300-0000000
NEXT_PUBLIC_JAZZCASH_NAME=A.K. Auto Care
NEXT_PUBLIC_EASYPAISA_NUMBER=0300-0000000
NEXT_PUBLIC_EASYPAISA_NAME=A.K. Auto Care
NEXT_PUBLIC_BANK_NAME=HBL
NEXT_PUBLIC_BANK_ACCOUNT=0000-0000000-001
NEXT_PUBLIC_BANK_BRANCH=PECHS, Karachi
NEXT_PUBLIC_BANK_TITLE=A.K. Auto Care

# ── Social links (leave blank to hide an icon) ───────────────
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/akautocare
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/akautocare
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@akautocare
NEXT_PUBLIC_YOUTUBE_URL=

# ── Analytics (optional but recommended) ─────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# ── Newsletter provider (optional — also stored in Supabase) ─
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# ── Abandoned-cart recovery cron (REQUIRED for that feature) ─
# Vercel automatically sends "Authorization: Bearer $CRON_SECRET" to the cron route.
# The same CRON_SECRET also guards the daily low-stock digest cron.
CRON_SECRET=change-me-to-a-long-random-string
CART_RECOVERY_SECRET=change-me-to-a-long-random-string

# ── Low-stock digest (optional) ──────────────────────────────
# Recipient for the daily low-stock email; falls back to CONTACT_EMAIL_TO.
LOW_STOCK_EMAIL_TO=

# ── Rate limiting — Upstash Redis (recommended for production) ─
# Without these, rate limiting falls back to a per-instance in-memory limiter
# (limits are not shared across serverless instances). Create a free Redis at
# upstash.com and paste the REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
